{
  "name": "@augmara/autara-ui",
  "version": "0.1.0",
  "description": "Shared UI components, design tokens, and Tailwind preset for Autara web apps",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens": "./src/tokens/index.css",
    "./tokens/*": "./src/tokens/*.css",
    "./utilities": "./src/utilities/index.css",
    "./utilities/*": "./src/utilities/*.css",
    "./preset": "./src/preset/index.mjs",
    "./preset/*": "./src/preset/*.mjs",
    "./cn": {
      "types": "./dist/lib/cn.d.ts",
      "default": "./dist/lib/cn.js"
    }
  },
  "files": [
    "dist",
    "src/tokens",
    "src/utilities",
    "src/preset"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/augmara/autara-ui.git"
  },
  "keywords": [
    "autara",
    "ui",
    "design-system",
    "tailwind"
  ],
  "author": "Autara",
  "license": "UNLICENSED",
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "motion": "^12.38.0",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^10.3.5",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/react": "^19.0.0",
    "semantic-release": "^23.1.1",
    "typescript": "^5.7.0"
  }
}
